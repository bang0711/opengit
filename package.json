{
  "name": "OpenGit",
  "version": "2.0.0",
  "private": true,
  "description": "A git client desktop app",
  "author": "Chau Chan Bang <chau.chan.bang@pwc.com>",
  "license": "MIT",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check",
    "format": "biome format --write",
    "icons": "node scripts/generate-icons.mjs",
    "licenses": "generate-license-file --input package.json --output THIRD-PARTY-NOTICES.txt --overwrite",
    "release": "node scripts/release.mjs",
    "electron:dev": "electron-vite dev",
    "electron:build": "node scripts/generate-icons.mjs && bun run licenses && electron-vite build && electron-builder",
    "electron:publish": "node scripts/generate-icons.mjs && bun run licenses && electron-vite build && electron-builder --publish always"
  },
  "build": {
    "appId": "com.opengit.desktop",
    "productName": "OpenGit",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "asar": true,
    "electronLanguages": [
      "en-US"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "bang0711",
        "repo": "OpenGit"
      }
    ],
    "files": [
      "out/**/*",
      "package.json",
      "THIRD-PARTY-NOTICES.txt",
      "!**/*.map"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenGit",
      "artifactName": "OpenGit-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "OpenGit-${version}-portable.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  },
  "trustedDependencies": [
    "electron",
    "electron-winstaller",
    "esbuild",
    "sharp"
  ],
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@remixicon/react": "^4.9.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^20",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "generate-license-file": "^4.2.1",
    "material-file-icons": "^2.4.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prismjs": "^1.30.0",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.11.2",
    "react-router-dom": "^7.18.0",
    "shadcn": "^4.11.0",
    "sharp": "^0.35.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
