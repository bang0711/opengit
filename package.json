{
  "name": "OpenGit",
  "version": "3.1.0",
  "private": true,
  "description": "A git client desktop app",
  "author": "Chau Chan Bang <chau.chan.bang@pwc.com>",
  "license": "MIT",
  "scripts": {
    "dev": "tauri dev",
    "dev:vite": "vite",
    "build": "tauri build && node scripts/collect-release.mjs",
    "build:vite": "vite build",
    "tauri": "tauri",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check",
    "format": "biome format --write",
    "licenses": "generate-license-file --input package.json --output THIRD-PARTY-NOTICES.txt --overwrite",
    "release": "node scripts/release.mjs"
  },
  "trustedDependencies": [
    "esbuild"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@tanstack/react-virtual": "^3.14.4",
    "@tauri-apps/api": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cmdk": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@remixicon/react": "^4.9.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^20",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "generate-license-file": "^4.2.1",
    "material-file-icons": "^2.4.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prismjs": "^1.30.0",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.11.2",
    "react-router-dom": "^7.18.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
