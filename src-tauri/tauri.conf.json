{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenGit",
  "version": "3.1.0",
  "identifier": "com.opengit.desktop",
  "build": {
    "beforeDevCommand": "bun run dev:vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenGit",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg",
      "appimage"
    ],
    "publisher": "Chau Chan Bang",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "displayLanguageSelector": false
      }
    }
  }
}
